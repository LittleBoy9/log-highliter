{
  "name": "log-highlighter-vscode",
  "displayName": "Log Highlighter",
  "description": "Highlight and manage console.log, console.warn, console.error and other console statements. Supports custom loggers like NestJS, Winston, Pino with one-click removal.",
  "version": "0.0.1",
  "publisher": "littleboy",
  "author": {
    "name": "Sounak Das"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sounakdas/log-highlighter"
  },
  "bugs": {
    "url": "https://github.com/sounakdas/log-highlighter/issues"
  },
  "homepage": "https://github.com/sounakdas/log-highlighter#readme",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Linters"
  ],
  "keywords": [
    "console",
    "log",
    "highlight",
    "debug",
    "cleanup",
    "remove",
    "nestjs",
    "winston",
    "pino",
    "logger"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:vue",
    "onLanguage:svelte"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Log Highlighter",
      "properties": {
        "logHighlighter.enabledPresets": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "enum": ["nestjs", "winston", "pino", "bunyan", "log4js"]
          },
          "description": "Enable built-in presets for common logging frameworks"
        },
        "logHighlighter.customPatterns": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for this pattern"
              },
              "pattern": {
                "type": "string",
                "description": "Text to match (e.g., 'Logger.log', 'this.logger.warn')"
              },
              "color": {
                "type": "string",
                "description": "Hex color for highlighting (e.g., '#22c55e')"
              }
            },
            "required": ["name", "pattern", "color"]
          },
          "description": "Custom logging patterns to highlight"
        }
      }
    },
    "commands": [
      {
        "command": "log-highlighter.showMenu",
        "title": "Log Highlighter: Show Menu",
        "icon": "$(list-filter)"
      },
      {
        "command": "log-highlighter.highlightAll",
        "title": "Log Highlighter: Highlight All Console Statements"
      },
      {
        "command": "log-highlighter.highlightLog",
        "title": "Log Highlighter: Highlight console.log"
      },
      {
        "command": "log-highlighter.highlightWarn",
        "title": "Log Highlighter: Highlight console.warn"
      },
      {
        "command": "log-highlighter.highlightError",
        "title": "Log Highlighter: Highlight console.error"
      },
      {
        "command": "log-highlighter.highlightInfo",
        "title": "Log Highlighter: Highlight console.info"
      },
      {
        "command": "log-highlighter.highlightDebug",
        "title": "Log Highlighter: Highlight console.debug"
      },
      {
        "command": "log-highlighter.removeAll",
        "title": "Log Highlighter: Remove All Highlighted Statements"
      },
      {
        "command": "log-highlighter.clearHighlights",
        "title": "Log Highlighter: Clear All Highlights"
      },
      {
        "command": "log-highlighter.managePresets",
        "title": "Log Highlighter: Manage Framework Presets"
      },
      {
        "command": "log-highlighter.highlightCustom",
        "title": "Log Highlighter: Highlight Custom Patterns"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "log-highlighter.showMenu",
          "when": "resourceLangId =~ /javascript|typescript|javascriptreact|typescriptreact|vue|svelte/",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  }
}
